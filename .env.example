# Central API base URL
# - Direct API:  http://<api-host>:4000
# - Behind proxy: https://<monitoring-host>/api
CENTRAL_API_URL=https://monitoring.edge.ge/api

# Name shown in dashboard
SERVER_NAME=my-edge-server

# Agent key issued once by the central API (min 16 chars)
AGENT_API_KEY=replace-me-with-a-long-random-key

# Report cadence (seconds, 5-3600)
REPORT_INTERVAL_SECONDS=30

# Per-request HTTP timeout to the central API (ms, 1000-60000)
REPORT_HTTP_TIMEOUT_MS=15000

# Docker socket (Linux default). The agent only reads from it.
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Heartbeat file the Docker HEALTHCHECK and ops tools can stat.
AGENT_HEARTBEAT_PATH=/tmp/agent-heartbeat
